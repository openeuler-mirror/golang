+	R_LOONG64_GOTPCREL_HI
+	R_LOONG64_GOTPCREL_LO
+
 	// R_ADDRMIPSU (only used on mips/mips64) resolves to the sign-adjusted "upper" 16
 	// bits (bit 16-31) of an external address, by encoding it into the instruction.
 	R_ADDRMIPSU
